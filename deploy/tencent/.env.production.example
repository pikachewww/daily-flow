NODE_ENV=production
PORT=3001
DATABASE_PATH=/var/data/checkin.sqlite

# 腾讯云服务器反向代理域名，例如 api.example.com
API_DOMAIN=api.example.com
ACME_EMAIL=you@example.com

# 小程序正式域名，例如 https://servicewechat.com 或后续 Web 管理后台域名。
# 纯小程序调用时可先填 *，上线稳定后收紧。
CORS_ORIGIN=*

# AI Provider: local | openai | gemini | deepseek | claude
AI_PROVIDER=local
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
CLAUDE_API_KEY=

# 预留：腾讯云 COS 文件存储，后续头像/图片上传使用。
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_COS_BUCKET=
TENCENT_COS_REGION=ap-guangzhou
